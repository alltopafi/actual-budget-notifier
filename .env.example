# Actual Budget Connection details (Treat as SECRETS)
ACTUAL_SERVER_URL=https://your-actual-server.com
ACTUAL_SERVER_PASSWORD=your_actual_server_password
ACTUAL_BUDGET_SYNC_ID=your_budget_sync_id

# Actual Budget End-to-End Encryption (Optional, treat as SECRET)
# Leave blank or omit if E2EE is not enabled for your budget
ACTUAL_ENCRYPTION_PASSWORD=

# Discord Notifications (Treat as SECRET)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/xxxx

# Notifier Settings (Optional)
# How often to check Actual Budget for new transactions (in minutes). Default: 5
SCAN_INTERVAL_MINUTES=5

# How far back in time to check for transactions (in days). Default: 7
LOOKBACK_DAYS=7

# Internal storage paths (Optional)
# Local directory to store Actual Budget's internal sqlite cache. Default: data/actual-data
ACTUAL_DATA_DIR=data/actual-data

# Path to the JSON state file to track notified transactions. Default: data/state.json
STATE_FILE_PATH=data/state.json
